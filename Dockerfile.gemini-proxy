FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    aiohttp==3.13.2 \
    certifi \
    python-dotenv

COPY backend/gemini_proxy.py .
COPY backend/data/meeting_data.py ./data/meeting_data.py

EXPOSE 4000

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:4000/v1/models')" || exit 1

CMD ["python", "gemini_proxy.py"]
