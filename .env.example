# ── Gemini Proxy ──────────────────────────────────────────────────────────────
# Required: your Google Gemini API key
GEMINI_API_KEY=''

# Optional: port the gemini proxy listens on (default: 4000)
# GEMINI_PROXY_PORT=4000

# ── Open WebUI ────────────────────────────────────────────────────────────────
# Required in production: strong random string used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
WEBUI_SECRET_KEY=''

# Optional: host port to access the UI on (default: 3000)
# Maps to container port 8080.  Access via http://<server-ip>:3000
# OPEN_WEBUI_PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Not needed in production (frontend and backend share the same origin).
# Only set this when running the Vite dev server separately.
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# ── Proxy / forwarding ────────────────────────────────────────────────────────
# For production behind a reverse proxy, set to the proxy IP (e.g. 127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# ── Telemetry (opt-out) ───────────────────────────────────────────────────────
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
